{
  "ConnectionStrings": {
    "AgroCore": "Server=SERVIDOR-CAMPO\\SQLEXPRESS;Database=AgroCore;User Id=agrocore_app;Password=__CAMBIAR__;TrustServerCertificate=True;MultipleActiveResultSets=true;Encrypt=True;Connection Timeout=30"
  },
  "Jwt": {
    "Issuer": "AgroCore.Api",
    "Audience": "AgroCore.Clients",
    "SecretKey": "__GENERAR_CLAVE_ALEATORIA_DE_AL_MENOS_64_CARACTERES__CAMBIAR_EN_PRODUCCION__",
    "AccessTokenMinutes": 30,
    "RefreshTokenDays": 30,
    "ClockSkewSeconds": 60
  },
  "Security": {
    "BcryptWorkFactor": 12,
    "MaxFailedLoginAttempts": 5,
    "LockoutMinutes": 15,
    "PasswordMinLength": 8,
    "RequireMfaForAdmins": false
  },
  "Sync": {
    "MaxBatchSize": 500,
    "DeltaWindowDays": 90,
    "ConflictPolicy": "LastWriteWinsWithLog"
  },
  "Cors": {
    "AllowedOrigins": [
      "https://localhost:5173",
      "http://localhost:5173",
      "https://agrocore.local"
    ]
  },
  "RateLimit": {
    "PermitLimit": 120,
    "WindowSeconds": 60,
    "QueueLimit": 20
  },
  "Arca": {
    "Enabled": false,
    "Environment": "Homologacion",
    "CuitEmisor": "",
    "CertPath": "Certs/arca.pfx",
    "CertPassword": "",
    "WsaaUrl": "https://wsaahomo.afip.gov.ar/ws/services/LoginCms",
    "WsfeUrl": "https://wswhomo.afip.gov.ar/wsfev1/service.asmx"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/agrocore-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "shared": true
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": { "Application": "AgroCore.Api" }
  },
  "AllowedHosts": "*"
}
